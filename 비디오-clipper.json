{
	"schemaVersion": "0.1.0",
	"name": "비디오 / 웨비나",
	"behavior": "create",
	"noteContentFormat": "{{content}}\n\n---\n## 인제스트 메모\n- 핵심 메시지: \n- 이해가 안 된 부분: \n- 연결될 개념 페이지: \n- 왜 저장했나: ",
	"properties": [
		{
			"name": "raw_type",
			"value": "video",
			"type": "text"
		},
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "channel",
			"value": "{{author}}",
			"type": "text"
		},
		{
			"name": "presenter",
			"value": "",
			"type": "text"
		},
		{
			"name": "video_date",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "created",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "description",
			"value": "{{description}}",
			"type": "text"
		},
		{
			"name": "tags",
			"value": "raw/video",
			"type": "multitext"
		},
		{
			"name": "ingest_status",
			"value": "pending",
			"type": "text"
		}
	],
	"triggers": [
		"youtube.com",
		"youtu.be"
	],
	"noteNameFormat": "{{title}}",
	"path": "raw/videos"
}
